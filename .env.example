# =============================================================================
# Cortex Desktop — Environment Template (DEVELOPMENT ONLY)
# =============================================================================
# Copy to `.env` and fill in your own keys for local development.
#
#   NEVER put real keys in THIS file — it is committed to git.
#   Installed/compiled builds do NOT read .env at all: API keys are managed
#   in-app via Settings -> Models & Providers (Windows Credential Manager).
# =============================================================================

# --- LLM Providers (BYOK) ----------------------------------------------------
# MiMo — supports token-plan (tp-...) and API (sk-...) keys
MIMO_API_KEY=your-mimo-key-here

# DeepSeek — https://platform.deepseek.com
DEEPSEEK_API_KEY=your-deepseek-key-here

# Anthropic (Claude) — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=your-anthropic-key-here

# OpenAI — https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-key-here

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-key-here

# Alibaba Qwen (DashScope / Model Studio)
DASHSCOPE_API_KEY=your-dashscope-key-here

# Mistral — https://console.mistral.ai/api-keys
MISTRAL_API_KEY=your-mistral-key-here

# SiliconFlow (embeddings) — https://cloud.siliconflow.com
SILICONFLOW_API_KEY=your-siliconflow-key-here

# --- Optional tuning ---------------------------------------------------------
# CORTEX_DEEPSEEK_MAX_OUTPUT_TOKENS=32768
# CORTEX_MIMO_READ_TIMEOUT_SEC=120
# CORTEX_MIMO_TOOL_READ_TIMEOUT_SEC=120
