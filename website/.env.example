# =============================================================================
# Cortex Server — Environment Variables
# =============================================================================
# Copy this file to `.env` and fill in the values.
# NEVER commit .env to version control.
# =============================================================================

# --- Django Core -------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-to-a-real-secret-key-50-chars-minimum
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# --- Database (production) ---------------------------------------------------
# SQLite is used in dev. Set DATABASE_URL for Postgres in production:
# DATABASE_URL=postgres://user:pass@localhost:5432/cortex

# --- Security (disabled in dev) ----------------------------------------------
DJANGO_SECURE_SSL_REDIRECT=False
DJANGO_SECURE_HSTS_SECONDS=0

# --- CORS --------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://localhost:8753,http://127.0.0.1:8753

# --- Admin -------------------------------------------------------------------
DJANGO_ADMIN_URL=ops/cortex-admin/

# --- Server URL (used in OAuth redirect) ------------------------------------
# Dev: http://127.0.0.1:8753
# Prod: https://cortex-ide.app
CORTEX_SERVER_URL=http://127.0.0.1:8753

# --- Social Auth — Google OAuth2 --------------------------------------------
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID → Web application
# 3. Add redirect URI: http://127.0.0.1:8000/auth/complete/google-oauth2/
#    Production: https://cortex-ide.app/auth/complete/google-oauth2/
GOOGLE_OAUTH2_KEY=
GOOGLE_OAUTH2_SECRET=

# --- Social Auth — GitHub OAuth ----------------------------------------------
# 1. Go to https://github.com/settings/developers → New OAuth App
# 2. Homepage URL: http://127.0.0.1:8000 (dev) or https://cortex-ide.app (prod)
# 3. Authorization callback URL: http://127.0.0.1:8000/auth/complete/github/
#    Production: https://cortex-ide.app/auth/complete/github/
GITHUB_OAUTH_KEY=
GITHUB_OAUTH_SECRET=

# --- Kickbox Email Verification ---------------------------------------------
# https://app.kickbox.com → Settings → API Keys
KICKBOX_API_KEY=

# =============================================================================
# PAYMENT GATEWAYS — Sandbox (Local Development)
# =============================================================================
# When DJANGO_DEBUG=True, these sandbox/test keys are used automatically.
# settings.py reads the SANDBOX keys and routes to sandbox/test APIs.
#
# PayPal Sandbox — https://developer.paypal.com/dashboard/applications/sandbox
#   1. Log in → My Apps & Credentials → Sandbox → Create App
#   2. Copy the Client ID and Secret below
#
# Razorpay Test — https://dashboard.razorpay.com/app/keys
#   1. Dashboard → Settings → API Keys → Generate Test Key
#   2. Keys start with rzp_test_xxx

# PayPal Sandbox
PAYPAL_SANDBOX_CLIENT_ID=
PAYPAL_SANDBOX_CLIENT_SECRET=
PAYPAL_SANDBOX_WEBHOOK_ID=

# Razorpay Test
RAZORPAY_TEST_KEY_ID=
RAZORPAY_TEST_KEY_SECRET=
RAZORPAY_TEST_WEBHOOK_SECRET=

# =============================================================================
# PAYMENT GATEWAYS — Production (Live)
# =============================================================================
# When DJANGO_DEBUG=False, these live keys are used automatically.
# settings.py reads the LIVE keys and routes to real payment APIs.
#
# PayPal Live — https://developer.paypal.com/dashboard/applications/live
#   1. Log in → My Apps & Credentials → Live → Create App
#   2. Copy the Client ID and Secret below
#   3. Set up webhook endpoint: https://yourdomain.com/payment/paypal/webhook/
#
# Razorpay Live — https://dashboard.razorpay.com/app/keys
#   1. Dashboard → Settings → API Keys → Generate Live Key (requires KYC)
#   2. Keys start with rzp_live_xxx
#   3. Set up webhook endpoint: https://yourdomain.com/payment/razorpay/webhook/

# PayPal Live
PAYPAL_LIVE_CLIENT_ID=
PAYPAL_LIVE_CLIENT_SECRET=
PAYPAL_LIVE_WEBHOOK_ID=

# Razorpay Live
RAZORPAY_LIVE_KEY_ID=
RAZORPAY_LIVE_KEY_SECRET=
RAZORPAY_LIVE_WEBHOOK_SECRET=

# --- Telemetry ---------------------------------------------------------------
TELEMETRY_RATE_LIMIT=10
TELEMETRY_RETENTION_DAYS=90

# =============================================================================
# LLM API KEYS — For subscription model proxy (Cortex-managed)
# =============================================================================
# These keys are used by the server to proxy requests for subscription users.
# Users on subscription plan use these keys (credits deducted).
# BYOK users use their own keys (stored in Windows Credential Manager).

# DeepSeek — V4 Pro models
DEEPSEEK_API_KEY=

# Xiaomi MiMo — V2.5 / V2.5 Pro models
# Supports both token plan (tp-*) and standard (sk-*) keys
# If tp-* fails, automatically falls back to sk-*
MIMO_API_KEY_TP=
MIMO_API_KEY_SK=

# Mistral — Large model (OCR/vision)
MISTRAL_API_KEY=

# SiliconFlow — Qwen embeddings, vision models
SILICONFLOW_API_KEY=
