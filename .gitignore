# ============================================================
# Cortex OSS — .gitignore
# Public open-source repository
# ============================================================

# ── Python ────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
eggs/
*.egg
.eggs/

# ── Virtual Environment ───────────────────────────────────────
venv/
.venv/
env/
.env
*.env
!.env.example

# ── IDE / Editor ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────
*.log
*.log.txt

# ── Cortex Private Files (DO NOT COMMIT) ──────────────────────
.cortex/
.cortexrc.json
.cortexrc*
.cortex_project_state/

# ── Private source code (excluded from public repo) ───────────
# Policy: EVERYTHING is open source except agent_bridge.py and the
# security/credential/safety modules below.
src/ai/agent_bridge.py
src/ai/agent_safety.py
src/core/auth_manager.py
src/core/key_manager.py
src/core/security.py
src/core/secure_http.py
src/core/secure_transmission.py
src/core/sandbox_manager.py
src/core/win_cred.py
src/core/cortex_api.py
src/core/security_audit.py
src/config/points_manager.py

# ── Build logs (artifacts, not source) ─────────────────────────
build_error.log
build_output.log
pyinstaller_build.log
iscc_build.log
installer_output/
bin/
launch_cortex.bat

# ── Pyright / LSP Audit ───────────────────────────────────────
pyright_audit.py
pyright_report.json

# ── Runtime Hooks (PyInstaller build helpers) ─────────────────
runtime_hook_encodings.py
runtime_hook_asyncio.py
runtime_hook_certifi.py
runtime_hook_noconsole.py

# ── Node Modules ──────────────────────────────────────────────
node_modules/

# ── Testing ───────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
benchmarks/
.benchmarks/

# ── Misc (dev-only files, not for public) ─────────────────────
demo_*.html
diff_card_demo.html
folder_icons_demo.html
fix_escape.py
behaviour.txt
error.log
error.txt
THEME_NOTIFICATION_FEATURE.md
MEMORY_SYSTEM_AUDIT.md
Docs/app.md

# ── Django website — internal docs (sensitive, do NOT leak) ───
website/Docs/app.md
website/Docs/CORTEX_REVENUE_PLAN.md
website/Docs/LAUNCH_PLAN_WINDOWS_BYOK.md
website/Docs/INDUSTRY_REVENUE_COMPARISON.md
website/Docs/AGENTIC_LOOP_IMPLEMENTATION.md

# ── Django website — secrets / runtime (NEVER commit) ─────────
website/.env
website/db.sqlite3
website/*.log
website/server.log
website/error.txt
website/client_secret_*.json
website/twilio_2FA_recovery_code.txt
website/*_recovery_code*.txt
website/*.pem
website/*.key
website/__pycache__/
website/**/__pycache__/
website/*.pyc
website/**/*.pyc
website/staticfiles/
website/media/

# ── MCP / Playwright ──────────────────────────────────────────
.playwright-mcp/

# ── Claude ────────────────────────────────────────────────────
.claude/
